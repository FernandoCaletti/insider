# ======================
# InsiderTrack Environment Variables
# ======================

# --- Supabase / PostgreSQL ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/insidertrack

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
CORS_ORIGINS=http://localhost:3000,https://insidertrack.com.br

# --- Pipeline ---
CVM_BASE_URL=https://dados.cvm.gov.br
CVM_RAD_URL=https://www.rad.cvm.gov.br/ENET/frmConsultaExternaItens.aspx
DOWNLOAD_DELAY_SECONDS=2
DOWNLOAD_TIMEOUT_SECONDS=30
DOWNLOAD_MAX_RETRIES=3
PIPELINE_BATCH_SIZE=100

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# --- Railway (Deploy) ---
RAILWAY_ENVIRONMENT=production

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
