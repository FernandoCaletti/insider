# ======================
# InSight Environment Variables
# ======================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://[YOUR-PROJECT].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- API (Railway) ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=production
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
LOG_LEVEL=INFO

# --- Pipeline ---
CVM_BASE_URL=https://dados.cvm.gov.br
CVM_RAD_URL=https://www.rad.cvm.gov.br/ENET/frmConsultaExternaItens.aspx
DOWNLOAD_DELAY_SECONDS=2
DOWNLOAD_TIMEOUT_SECONDS=30
DOWNLOAD_MAX_RETRIES=3
PIPELINE_BATCH_SIZE=100

# --- Frontend (Vercel) ---
# Set in Vercel dashboard:
NEXT_PUBLIC_API_URL=/api
# Internal URL for SSR rewrites (set in Vercel env vars):
API_URL_INTERNAL=https://your-api.up.railway.app

# --- Railway ---
RAILWAY_ENVIRONMENT=production

# --- Logging ---
LOG_FORMAT=json
